# ============================================
# PocketBuddy Environment Variables
# ============================================
# Copy this file to .env and fill in values

# --- Server ---
PORT=5000
NODE_ENV=development

# --- MongoDB ---
MONGODB_URI=mongodb://localhost:27017/pocketbuddy

# --- JWT ---
JWT_SECRET=change-me-to-a-strong-random-string
JWT_REFRESH_SECRET=change-me-to-another-strong-random-string
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# --- AI Provider (openai | anthropic | gemini) ---
AI_PROVIDER=openai
AI_MODEL=gpt-4o

# OpenAI
OPENAI_API_KEY=sk-...

# Anthropic (optional — used if AI_PROVIDER=anthropic)
ANTHROPIC_API_KEY=sk-ant-...

# Google Gemini (optional — used if AI_PROVIDER=gemini)
GEMINI_API_KEY=

# --- Plaid (optional) ---
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox

# --- AWS ---
AWS_REGION=us-east-1
AWS_S3_BUCKET=pocketbuddy-assets

# --- Client (Vite prefixed) ---
VITE_API_URL=http://localhost:5000/api
